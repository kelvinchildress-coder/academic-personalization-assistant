# Phase 7 dashboard environment variables — TEMPLATE.
#
# Copy this file to web/.env.local for local development. Never commit
# .env.local. In production, set these in the Vercel project settings,
# not in this file.
#
# All values below are placeholders.

# ----- Auth.js / NextAuth -----
# Random 32+ byte string. Generate with: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth client (created in Google Cloud Console).
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Public URL of the deployment. For local dev: http://localhost:3000
# For production: https://<your-vercel-domain>
NEXTAUTH_URL=

# ----- GitHub data PAT (Phase 7 Part 3) -----
# Fine-grained PAT scoped to this repo only, with Contents: Read-only.
# See web/DEPLOY.md (Part 7) for exact creation steps.
GITHUB_DATA_READ_PAT=
